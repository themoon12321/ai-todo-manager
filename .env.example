# AI 代办系统 - 敏感配置
# 复制此文件为 .env 并填入真实值，.env 不会被提交到 Git

# 飞书 Base
FEISHU_BASE_TOKEN=your_base_token_here
FEISHU_ACTIVE_TABLE=tblxxx
FEISHU_ARCHIVE_TABLE=tblxxx
FEISHU_LONGTERM_TABLE=tblxxx

# DeepSeek API（定时推送润色用）
DEEPSEEK_API_KEY=your_api_key_here
DEEPSEEK_MODEL=deepseek-chat

# lark-cli 路径
LARK_CLI_PATH=D:\D_software\LarkCLI\lark-cli.cmd

# 飞书用户 ID（用于推送消息到你的飞书）
FEISHU_USER_ID=your_open_id_here

# CCconnect 配置（微信渠道，可选）
CC_DATA_DIR=D:\D_software\cc-connect\data
CC_PROJECT=wechat

# 推送渠道：feishu / wechat / feishu,wechat（同时推多个）
PUSH_CHANNEL=feishu
